<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Home - PahiramKotse</title>
    <link rel="stylesheet" href="/global.css">
    <link rel="stylesheet" href="/homepage.css">
</head>
<body>

    <div class="header-flex">
        <div class="logo">
            <img src="/images/logo.png" width="300px">
        </div>
        <ul class="navlinks">
            <li><h3>Admin Page</h3></li>
            <li>
                <a href="/admin-profile">
                    <img src="/images/{{user.profilePicture}}" alt="Profile" width="40px" height="40px" style="border-radius:50%; object-fit: cover;">
                </a>
            </li>
         </ul>
    </div>

    <div class="home-flex">

        <div class="home-left">
            <h2>Administrator Dashboard</h2>

            <div class="proceed">
                <a href="/manage-users" class="regbtn">Manage Users</a>
            </div>
            <br><br>

            <div class="proceed">
                <a href="/manage-vehicles" class="regbtn">Manage Vehicles</a>
            </div>
            <br><br>

            <div class="proceed">
                <a href="/manage-reservations" class="regbtn">Manage Reservations</a>
            </div>

        </div>

        <div class="home-right">
            <section class="carssection">
                <h2>System Overview</h2>

                <div class="cards-container">
                    <div class="carsquare">
                        <h3>Total Users</h3>
                        <p>{{totalUsers}} Registered Customers</p>
                    </div>

                    <div class="carsquare">
                        <h3>Active Reservations</h3>
                        <p>{{activeReservations}} Ongoing Bookings</p>
                    </div>

                    <div class="carsquare">
                        <h3>Available Vehicles</h3>
                        <p>{{availableVehicles}} Cars Ready</p>
                    </div>
                </div>
            </section>
        </div>

    </div>

</body>
</html>