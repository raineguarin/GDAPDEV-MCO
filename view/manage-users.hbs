<!DOCTYPE html>
<html>
<head>
    <title>Manage Users</title>
    <link rel="stylesheet" href="/manage-users.css">
    <link rel="stylesheet" href="/global.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
</head>

<body>
    <div class="header-flex">
        <div class="logo">
            <img src="/images/logo.png" width="300px" alt="Logo">
        </div>
        <ul class="navlinks">
           <li><a href="/admin-homepage">To Dashboard</a></li>
            <li>
                <a href="/admin-profile">
                    <img src="/images/{{user.profilePicture}}" alt="Profile" width="40px" height="40px" style="border-radius:50%; object-fit: cover;">
                </a>
            </li>
        </ul>
    </div>

    <div class="name">
        <h1>Manage Users</h1>
        <p>Admin</p>
    </div>

    <div class="boxcontainer">
        
        <div class="top-bar">
            <div class="search-user">
                <input type="text" id="searchInput" placeholder="Search Username/Email...">
            </div>

            <div class="icons">
                <button id="addBtn" class="btn-add"><i class="fa-solid fa-plus"></i> Add User</button>
                <button id="editBtn" class="btn-edit" disabled><i class="fa-solid fa-pen-to-square"></i> Edit User</button>
                <button id="deleteBtn" class="btn-delete" disabled><i class="fa-solid fa-trash"></i> Delete User</button>
            </div>
        </div>

        <div class="filters">
            <select id="filterRole">
                <option value="all">All Roles</option>
                <option value="Admin">Admin</option>
                <option value="Customer">Customer</option>
            </select>

            <select id="filterStatus">
                <option value="all">All Statuses</option>
                <option value="Active">Active</option>
                <option value="Suspended">Suspended</option>
            </select>

            <select id="filterVerified">
                <option value="all">License Status</option>
                <option value="true">Verified</option>
                <option value="false">Not Verified</option>
            </select>
        </div>

        <div class="users-grid" id="usersGrid">
            {{#each users}}
            <div class="user-card" 
                 data-id="{{this._id}}" 
                 data-username="{{this.username}}" 
                 data-name="{{this.name}}" 
                 data-email="{{this.email}}" 
                 data-role="{{this.role}}"
                 data-status="{{this.status}}"
                 data-verified="{{this.isVerified}}"
                 data-license="{{this.licenseNumber}}">
                 
                <div class="user-info">
                    <h2>{{this.name}}</h2>
                    <p><strong>Username:</strong> {{this.username}}</p>
                    <p><strong>Email:</strong> {{this.email}}</p>
                    <p><strong>Role:</strong> {{this.role}}</p>
                    
                   {{#if (eq this.role 'Admin')}}
                        <p><strong>Staff ID:</strong> {{this.staffID}}</p>
                    {{else}}
                        <p>
                            <strong>License:</strong> 
                           {{#if this.isVerified}}
                                <span class="verified-text">Verified</span>
                            {{else}}
                                <span class="not-verified-text">Not Verified</span>
                            {{/if}}
                        </p>
                        <p>
                            <strong>Status:</strong> 
                            {{#if (eq this.status 'Suspended')}}
                                <span class="suspended-text">Suspended</span>
                            {{else}}
                                <span class="active-text">Active</span>
                            {{/if}}
                        </p>
                    {{/if}}
                </div>
            </div>
            {{/each}}
        </div>
    </div>

    <footer>
        <div class="footerContainer">
            <a href="/manage-users" class="disable-link">Manage Users</a>
            <a href="/manage-vehicles" class="disable-link">Manage Vehicles</a>
            <a href="/manage-reservations" class="disable-link">Manage Reservations</a>
        </div>
    </footer>
        
    <div id="userFormModal" class="popup">
            <div class="Popupcontent form-popup">
                <h2 id="formModalTitle">Add New User</h2>
                <hr>
                    <form id="userForm">
                        <input type="hidden" id="formUserId">
                        
                        <label>Role:</label>
                        <select id="formRole">
                            <option value="Customer">Customer</option>
                            <option value="Admin">Admin</option>
                        </select>

                        <label>Name:</label>
                        <input type="text" id="formName" required>

                        <label>Username:</label>
                        <input type="text" id="formUsername" required>
                        
                        <label>Email:</label>
                        <input type="email" id="formEmail" required>
                        
                        <div id="customerFields" style="display: flex; flex-direction: column; gap: 8px;">
                            <label>License Number:</label>
                            <input type="text" id="formLicense">

                            <label>License Verification:</label>
                            <select id="formIsVerified">
                                <option value="false">Not Verified</option>
                                <option value="true">Verified</option>
                            </select>

                            <label>Account Status:</label>
                            <select id="formStatus">
                                <option value="Active">Active</option>
                                <option value="Suspended">Suspended</option>
                            </select>
                        </div>

                        <div class="modal-buttons">
                            <button type="button" class="cancel" id="formCancelBtn">Cancel</button>
                            <button type="submit" class="proceed btn-add" id="formSaveBtn">Save User</button>
                        </div>
                </form>
            </div>
        </div>

        <div id="manageconf" class="popup">
            <div class="Popupcontent">
                <h2>Confirm Action</h2>
                <hr>
                <div>
                    <p>Are you sure you want to delete user <strong id="deleteTargetName"></strong>?</p>
                    <p class="warning-text">This action cannot be undone.</p>
                    <div class="modal-buttons">
                        <button class="cancel" id="deleteCancelBtn">No, Go Back</button>
                        <button class="proceed btn-delete" id="deleteConfirmBtn">Yes, Confirm</button>
                    </div>
                </div>
            </div>
        </div>

        <script src="/manage-users.js"></script>
    </body>
    </html>